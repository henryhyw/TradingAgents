# Vertex AI default (ADC/service account). Optional OpenAI fallback:
# OPENAI_API_KEY=

# LLM provider defaults
TRADINGAGENTS_LLM_PROVIDER=vertex
TRADINGAGENTS_LLM_MODEL=gemini-2.5-flash
TRADINGAGENTS_LLM_DEEP_MODEL=gemini-2.5-flash
TRADINGAGENTS_LLM_QUICK_MODEL=gemini-2.5-flash
TRADINGAGENTS_VERTEX_PROJECT=ta-henry-2026
TRADINGAGENTS_VERTEX_REGION=us-central1
TRADINGAGENTS_LLM_TIMEOUT_SECONDS=90
TRADINGAGENTS_LLM_MAX_RETRIES=1

# GCP artifact publishing (optional for local runs, enabled on VM)
TRADINGAGENTS_GCP_PROJECT_ID=ta-henry-2026
TRADINGAGENTS_GCP_REGION=us-central1
TRADINGAGENTS_GCP_ZONE=us-central1-a
TRADINGAGENTS_GCP_VM_NAME=ta-runner-01
TRADINGAGENTS_GCS_BUCKET=ta-artifacts-ta-henry-2026
TRADINGAGENTS_GCP_SERVICE_ACCOUNT_NAME=ta-runner-sa
TRADINGAGENTS_PUBLISH_ON_RUN=false

# Optional trading/risk overrides
TRADINGAGENTS_SHORTLIST_SIZE=8
TRADINGAGENTS_STARTING_CASH=100000
TRADINGAGENTS_MAX_SHORTLIST_PER_SECTOR=2
TRADINGAGENTS_MAX_SECTOR_EXPOSURE=0.15
TRADINGAGENTS_CORRELATION_THRESHOLD=0.85
TRADINGAGENTS_VOL_TARGET=0.28
TRADINGAGENTS_MIN_REGIME_PROXY_COVERAGE=0.70
TRADINGAGENTS_MIN_SHORTLIST_DATA_COVERAGE=0.80
TRADINGAGENTS_HISTORY_RETRY_ATTEMPTS=2
TRADINGAGENTS_MAX_EXTENSION_OVER_MA20=0.09
TRADINGAGENTS_OVERHEAT_RSI_THRESHOLD=78
TRADINGAGENTS_OVERHEAT_EXTENSION=0.14
TRADINGAGENTS_ENTRY_CONFIDENCE_MIN=0.58
TRADINGAGENTS_TRIM_PROFIT_TRIGGER=0.10
TRADINGAGENTS_REDUCE_TO_CORE_PROFIT_TRIGGER=0.18
TRADINGAGENTS_TIME_STOP_DAYS=8
